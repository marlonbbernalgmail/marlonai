# Port this connector listens on
PORT={{PORT}}

# Ollama base URL (local machine)
OLLAMA_BASE_URL={{OLLAMA_BASE_URL}}

# Ollama model to use
OLLAMA_MODEL=gemma4

# Optional response tuning for grounded portfolio/interview answers
OLLAMA_TEMPERATURE=0.2
OLLAMA_TOP_P=0.9
OLLAMA_REPEAT_PENALTY=1.08
# Optional: uncomment if your model needs a larger context window
# OLLAMA_NUM_CTX=8192

# Shared secret — must match the value set in your Vercel environment
VERCEL_SHARED_API_KEY={{VERCEL_SHARED_API_KEY}}

# Your Vercel portfolio origin (optional — leave blank to skip origin check)
ALLOWED_ORIGIN={{ALLOWED_ORIGIN}}

# Paths to prompt/context files (relative to project root)
SYSTEM_PROMPT_FILE={{SYSTEM_PROMPT_FILE}}
PROFILE_CONTEXT_FILE={{PROFILE_CONTEXT_FILE}}

# ── MySQL (interaction logging & IP blocking) ─────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER={{MYSQL_USER}}
MYSQL_PASSWORD={{MYSQL_PASSWORD}}
MYSQL_DATABASE=marlonai_logs

# ── Admin dashboard (https://your-domain/admin) ───────────────────────────────
# Login: username=admin, password=<value below>
ADMIN_PASSWORD={{ADMIN_PASSWORD}}
